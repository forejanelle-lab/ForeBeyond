# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://pudfethylijrfilcihgp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# App URL — required in production (verification email links)
NEXT_PUBLIC_APP_URL=https://fore-beyond.vercel.app

# Resend — auth + transactional email from hello@forebeyond.com
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Fore Beyond <hello@forebeyond.com>

# Supabase Management API (optional; or run `npx supabase login`)
# SUPABASE_ACCESS_TOKEN=

# Migrations — local only
# DATABASE_URL=postgresql://postgres.pudfethylijrfilcihgp:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Stripe — stay service fee payments
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Traveler (guest) signup — enabled automatically in `npm run dev`; set true to allow in production
# NEXT_PUBLIC_TRAVELER_SIGNUP_ENABLED=true
