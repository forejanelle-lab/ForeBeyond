# Supabase — Fore Beyond
# Project: https://supabase.com/dashboard/project/pudfethylijrfilcihgp

# Client (required for auth + data)
NEXT_PUBLIC_SUPABASE_URL=https://pudfethylijrfilcihgp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server-side only — Session pooler (IPv4). Get yours from Dashboard → Settings → Database
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.pudfethylijrfilcihgp:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Optional — used by npm run db:discover
# DATABASE_PASSWORD=your_database_password

# Vercel Analytics — no env vars required when deployed on Vercel
# Enable Web Analytics in Vercel Dashboard → Project → Analytics

# Admin access — set in database, not via env vars:
# UPDATE profiles SET is_admin = true WHERE email = 'your@email.com';
